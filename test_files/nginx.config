upstream ts_backend {
    # Backend: docker-compose network_mode: host → uvicorn слушает порт 8000 на том же хосте, что и nginx.
    # 502 / connection refused = процесс backend не запущен или другой порт (см. converter-agent README).
    server 127.0.0.1:8000;
}

server {
    server_name ts.syharik.ru;
    listen 91.204.75.184:80;
    return 301 https://$host$request_uri;

    error_log /var/www/syharik3316__usr/data/logs/ts.syharik.ru-frontend.error.log;
    access_log /var/www/syharik3316__usr/data/logs/ts.syharik.ru-frontend.access.log;
}

server {
    server_name ts.syharik.ru;
    listen 91.204.75.184:443 ssl;

    ssl_certificate "/var/www/httpd-cert/syharik.ru_2026-03-17-15-19_03.crt";
    ssl_certificate_key "/var/www/httpd-cert/syharik.ru_2026-03-17-15-19_03.key";

    charset utf-8;

    gzip on;
    gzip_min_length 1024;
    gzip_proxied expired no-cache no-store private auth;
    gzip_types text/css image/x-ico application/pdf image/jpeg image/png image/gif application/javascript application/x-javascript application/x-pointplus;
    gzip_comp_level 1;

    set $root_path /var/www/syharik3316__usr/data/www/syharik.ru/typescript-site/frontend/dist;
    root $root_path;
    index index.html;
    disable_symlinks if_not_owner from=$root_path;

    client_max_body_size 50m;

    # Важно: includes FastPanel должны идти ПЕРЕД нашими location, иначе дублирующий
    # location /auth (или другой API) в include может переопределить прокси и дать 502 только новым путям.
    include "/etc/nginx/fastpanel2-sites/syharik3316__usr/ts.syharik.ru.includes";
    include /etc/nginx/fastpanel2-includes/*.conf;

    # Единый прокси на FastAPI: generate, infer-schema, health, auth, история генераций (/me/…), docs.
    # Префикс /me обязателен: иначе GET /me/generations уйдёт в SPA (index.html) и фронт увидит «ожидался JSON».
    # HTTP 500 с этого location почти всегда от uvicorn/FastAPI — смотрите логи бэкенда, не nginx.
    location ~ ^/(generate|infer-schema|health|auth|docs|redoc|openapi\.json|me|stats|observability)(/.*)?$ {
        proxy_pass http://ts_backend;
        include /etc/nginx/proxy_params;
        proxy_connect_timeout 60s;
        proxy_send_timeout 600s;
        proxy_read_timeout 600s;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
    }

    # PATCH /profile — API; GET /profile и /profile/… — SPA (страница профиля и deep links).
    # Нельзя использовать limit_except { include proxy_params; }: внутри limit_except
    # директивы proxy_set_header из proxy_params не разрешены → [emerg] "proxy_set_header" is not allowed here.
    # Паттерн return + error_page + именованный location — обход без limit_except.
    location /profile {
        error_page 418 = @profile_api;
        if ($request_method ~ ^(PATCH|OPTIONS)$) {
            return 418;
        }
        try_files $uri $uri/ /index.html;
    }

    location @profile_api {
        proxy_pass http://ts_backend;
        include /etc/nginx/proxy_params;
        proxy_connect_timeout 60s;
        proxy_send_timeout 600s;
        proxy_read_timeout 600s;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
    }

    # SPA (статические файлы) из dist.
    location / {
        try_files $uri $uri/ /index.html =404;
    }

    location ^~ /assets/ {
        try_files $uri =404;
    }

    error_log /var/www/syharik3316__usr/data/logs/ts.syharik.ru-frontend.error.log;
    access_log /var/www/syharik3316__usr/data/logs/ts.syharik.ru-frontend.access.log;
}
