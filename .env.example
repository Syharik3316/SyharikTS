# Backend model provider: stub | ollama | openai_compatible | gigachat
LLM_PROVIDER=gigachat

# Use OpenAI-compatible API (also usable for GigaChat with compatible endpoint)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# GigaChat (OpenAI-compatible API)
# Default base URL uses OpenAI-compatible endpoint from GigaChat docs.
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# Token as api_key (optional)
GIGACHAT_API_KEY=
# Authorization header value, e.g. "Bearer <token>" (optional; can be used instead of GIGACHAT_API_KEY)
GIGACHAT_AUTHORIZATION_KEY=
## Model name (optional). If empty, backend uses a default.
GIGACHAT_MODEL=

# If you get TLS errors (self-signed certs), keep false.
GIGACHAT_VERIFY_TLS=false

# Increase if model output is truncated.
GIGACHAT_MAX_TOKENS=2000
GIGACHAT_TIMEOUT_SECONDS=90

# Ollama base URL
OLLAMA_BASE_URL=http://host.docker.internal:11434

# CORS
CORS_ALLOW_ORIGINS=*

# Frontend API base URL (used by Vite).
# В браузере `localhost` означает машину пользователя, поэтому для docker-compose
# обычно нужно именно http://localhost:8000 (backend публикуется на хосте).
VITE_API_BASE_URL=http://localhost:8000

## Auth (MySQL + JWT + ReCaptcha v2 + SMTP)

# MySQL connection (docker-compose mysql; при отсутствии будет использован sqlite auth.db)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=converter_agent
DB_USER=converter_agent
DB_PASSWORD=change-me

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_MINUTES=60

# ReCaptcha v2
RECAPTCHA_V2_SITE_KEY=
RECAPTCHA_V2_SECRET_KEY=

# Email (SMTP)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=noreply@your-domain.com

# TTL code (seconds)
AUTH_CODE_TTL_SECONDS=600

