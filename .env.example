# Backend model provider: stub | openai_compatible | gigachat
LLM_PROVIDER=gigachat

# Use OpenAI-compatible API (also usable for GigaChat with compatible endpoint)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# GigaChat (OpenAI-compatible API)
# Default base URL uses OpenAI-compatible endpoint from GigaChat docs.
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# Access token for direct Bearer auth (optional).
# You can pass raw token or "Bearer <token>".
GIGACHAT_API_KEY=
# Either:
# 1) "Bearer <token>" for direct auth, or
# 2) OAuth authorization key (Basic base64 from LK) for token exchange.
GIGACHAT_AUTHORIZATION_KEY=
## Model name (optional). If empty, backend uses a default.
GIGACHAT_MODEL=

# If you get TLS errors (self-signed certs), keep false.
# Warning about unverified HTTPS is suppressed automatically when false.
GIGACHAT_VERIFY_TLS=false
# OAuth scope must match permissions bound to your authorization key.
# Common value for personal accounts: GIGACHAT_API_PERS
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Leave empty or set 0 to use provider default (no local max_tokens cap).
GIGACHAT_MAX_TOKENS=
# Number of retries when model returns truncated TypeScript.
GIGACHAT_RETRY_ATTEMPTS=3
GIGACHAT_TIMEOUT_SECONDS=90
GIGACHAT_OAUTH_RETRY_ATTEMPTS=3
GIGACHAT_OAUTH_RETRY_DELAY_MS=1200
# Parser limits. Leave empty or set 0 for no local limits.
PARSE_MAX_ROWS=
PARSE_MAX_TEXT_CHARS=
# PNG/JPEG/TIFF: OCR выполняется локально через Tesseract.
# OCR_LANG: языки tesseract (например, rus+eng или eng).
OCR_LANG=rus+eng
# OCR_PSM: page segmentation mode (0..13), по умолчанию 6.
OCR_PSM=6
# OCR_FALLBACK_PSM: дополнительный PSM для TIFF-сканов.
OCR_FALLBACK_PSM=4

# CORS
CORS_ALLOW_ORIGINS=*

# Optional external PostgreSQL (async SQLAlchemy + asyncpg).
# Backend uses network_mode: host — в DATABASE_URL укажите 127.0.0.1:
# DATABASE_URL=postgresql+asyncpg://appuser:secret@127.0.0.1:5432/appdb
# DATABASE_URL=
# TCP connect timeout to Postgres in seconds (asyncpg); avoids hanging /health if DB is unreachable.
# DATABASE_CONNECT_TIMEOUT=10

# Frontend API base URL (used by Vite).
# Keep empty to use same-origin requests (/generate, /infer-schema) via nginx proxy.
# Set explicitly only for local direct backend access (e.g. http://localhost:8000).
VITE_API_BASE_URL=

# Цель прокси dev-сервера Vite → uvicorn (только server-side, не в bundle).
# Нужна при пустом VITE_API_BASE_URL и `npm run dev`: иначе /me/generations отдаст index.html.
DEV_API_PROXY_TARGET=http://127.0.0.1:8000

# --- Auth (required when DATABASE_URL is set for protected API) ---
# Strong secret, 32+ characters (e.g. openssl rand -hex 32).
JWT_SECRET=
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
# Макс. размер сырого файла (байты) для сохранения base64 в истории (проверка TS без повторной загрузки). Пусто = 8 MiB.
# GENERATION_HISTORY_MAX_INPUT_BYTES=
# Optional; default 15.
# VERIFICATION_CODE_TTL_MINUTES=15
# Cooldown between resend registration codes (seconds). Default 60.
# RESEND_VERIFICATION_COOLDOWN_SECONDS=60

# reCAPTCHA v2: secret for backend (siteverify). Required for /auth/register and /auth/reset-request.
RECAPTCHA_SECRET_KEY=

# SMTP (registration / password reset emails). If SMTP_HOST is empty, emails are logged only (dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# reCAPTCHA v2 site key for frontend build (Vite). Required for registration and password reset (step 1).
# Vite reads this from this file at repo root (frontend/vite.config.ts envDir).
VITE_RECAPTCHA_SITE_KEY=

