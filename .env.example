# Backend model provider: stub | ollama | openai_compatible | gigachat
LLM_PROVIDER=gigachat

# Use OpenAI-compatible API (also usable for GigaChat with compatible endpoint)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# GigaChat (OpenAI-compatible API)
# Default base URL uses OpenAI-compatible endpoint from GigaChat docs.
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# Token as api_key (optional)
GIGACHAT_API_KEY=
# Authorization header value, e.g. "Bearer <token>" (optional; can be used instead of GIGACHAT_API_KEY)
GIGACHAT_AUTHORIZATION_KEY=
## Model name (optional). If empty, backend uses a default.
GIGACHAT_MODEL=

# If you get TLS errors (self-signed certs), keep false.
GIGACHAT_VERIFY_TLS=false
# OAuth scope must match permissions bound to your authorization key.
# Common value for personal accounts: GIGACHAT_API_PERS
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Leave empty or set 0 to use provider default (no local max_tokens cap).
GIGACHAT_MAX_TOKENS=
# Number of retries when model returns truncated TypeScript.
GIGACHAT_RETRY_ATTEMPTS=3
GIGACHAT_TIMEOUT_SECONDS=90

# Parser limits. Leave empty or set 0 for no local limits.
PARSE_MAX_ROWS=
PARSE_MAX_TEXT_CHARS=
OCR_LANG=eng+rus
OCR_PSM=6
OCR_FALLBACK_PSM=11

# Ollama base URL
OLLAMA_BASE_URL=http://host.docker.internal:11434

# CORS
CORS_ALLOW_ORIGINS=*

# Frontend API base URL (used by Vite).
# Keep empty to use same-origin requests (/generate, /infer-schema) via nginx proxy.
# Set explicitly only for local direct backend access (e.g. http://localhost:8000).
VITE_API_BASE_URL=

